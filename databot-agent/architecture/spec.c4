// Element kinds, tags, and custom colors for the `databot-agent` architecture model.
//
// Tags encode delivery state so planned / future work is visually distinct
// from what is already shipping:
//   #built     — code path exists and is used today
//   #evolving  — built, but the surface/contract is still moving
//   #planned   — designed or partially scaffolded, not a stable surface yet
//   #research  — speculative / aspirational direction
//
// This is a PUBLIC architecture view of a PRIVATE repository. Element names and
// data flow are shown; secrets, internal hostnames, project ids, and other
// sensitive identifiers are deliberately generalized.

specification {

  element actor {
    style {
      shape person
      color secondary
    }
  }

  element externalSystem {
    style {
      shape rectangle
      color slate
    }
  }

  element system

  element container {
    style {
      shape rectangle
    }
  }

  element component

  element datastore {
    style {
      shape cylinder
    }
  }

  // Deployment model — where each piece runs.
  deploymentNode host {
    style {
      shape rectangle
      color slate
    }
  }
  deploymentNode proc

  tag built {
    color #16a34a
  }
  tag evolving {
    color #d97706
  }
  tag planned {
    color #64748b
  }
  tag research {
    color #6366f1
  }

  // Cross-cutting: carried by any element that is a known risk / open question
  // for a design review (in addition to its delivery-state tag).
  tag risk {
    color #dc2626
  }
}
