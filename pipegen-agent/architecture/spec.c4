// Element kinds, tags, and custom colors for the `pipegen-agent` architecture model.
//
// PUBLIC architecture view of a private repository. Names, data flow, and
// design are shared; secrets, internal hostnames/resource ids, customer
// names, and PII are deliberately excluded — external systems are described
// generically (e.g. "object storage", "the inference provider").
//
// Tags encode delivery state so planned / research work is visually distinct
// from what is already built:
//   #built     — code path exists and is exercised
//   #evolving  — built but the contract / coverage is still moving
//   #planned   — designed, not yet implemented (or v1 is a stub/heuristic)
//   #research  — speculative research / phase-2 track

specification {

  element actor {
    style {
      shape person
      color secondary
    }
  }

  element externalSystem {
    style {
      shape rectangle
      color slate
    }
  }

  element system

  element container {
    style {
      shape rectangle
    }
  }

  element component

  element datastore {
    style {
      shape cylinder
    }
  }

  // Deployment model — where each piece runs at review time.
  deploymentNode host {
    style {
      shape rectangle
      color slate
    }
  }
  deploymentNode proc

  tag built {
    color #16a34a
  }
  tag evolving {
    color #d97706
  }
  tag planned {
    color #64748b
  }
  tag research {
    color #6366f1
  }

  // Cross-cutting: carried by any element that is a known risk / open question
  // for the design review (in addition to its delivery-state tag).
  tag risk {
    color #dc2626
  }
}
